---
import { ACQUISITION_MAILTO, cfImageUrl, CF_IMAGES } from '../config/site';

const heroImage = cfImageUrl(CF_IMAGES.heroImageId);
---

<header class="domain-hero text-white relative overflow-hidden">
  <div
    class="absolute inset-0 opacity-25"
    style={`background-image: url('${heroImage}'); background-size: cover; background-position: center;`}
    aria-hidden="true"
  ></div>
  <div class="absolute inset-0 bg-gradient-to-br from-slate-900/90 via-slate-900/80 to-violet-950/60" aria-hidden="true"></div>

  <div class="relative z-10 max-w-screen-2xl mx-auto px-6 sm:px-8 pt-16 pb-20 md:pt-20 md:pb-24">
    <div class="max-w-4xl">
      <div class="inline-flex items-center gap-x-2 px-4 py-1.5 rounded-3xl bg-white/10 backdrop-blur-md border border-white/20 mb-8">
        <div class="w-2 h-2 bg-emerald-400 rounded-full animate-pulse"></div>
        <span class="text-xs font-semibold tracking-widest uppercase">Premium Tech &amp; Innovation Domain &bull; Available Now</span>
      </div>

      <h1 class="text-6xl md:text-7xl font-display tracking-tighter leading-none mb-6">
        PHX<span class="text-violet-400">.</span>Monster
      </h1>

      <p class="max-w-2xl text-2xl md:text-3xl font-light text-white/90 tracking-tight mb-10 leading-tight">
        The bold domain for <span class="font-medium text-white">Phoenix tech</span> — the monster rising in the Southwest.
      </p>

      <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
        <a
          href={ACQUISITION_MAILTO}
          class="conversion-cta group inline-flex items-center justify-center gap-x-3 px-9 py-4 text-lg font-semibold bg-violet-600 hover:bg-violet-500 active:bg-violet-700 text-white rounded-3xl transition-all shadow-xl shadow-violet-900/30"
        >
          <span>Secure This Domain</span>
          <i class="fa-solid fa-arrow-right group-active:translate-x-0.5 transition-transform"></i>
        </a>

        <a
          href="#facts"
          class="inline-flex items-center justify-center gap-x-2 px-7 py-4 text-base font-medium border border-white/30 hover:bg-white/10 text-white rounded-3xl transition-all"
        >
          <span>Why Phoenix is exploding</span>
        </a>
      </div>

      <div class="mt-10 flex flex-wrap items-center gap-x-8 gap-y-3 text-sm">
        <div class="flex items-center gap-x-2 text-white/70 text-xs font-medium tracking-wider">
          <i class="fa-solid fa-shield-halved text-emerald-400"></i>
          <span>SERIOUS INQUIRIES FROM TECH FOUNDERS, INVESTORS &amp; INNOVATORS</span>
        </div>
      </div>
    </div>
  </div>
</header>

<!-- Trust Bar -->
<div class="border-b border-slate-200 bg-white relative z-10">
  <div class="max-w-screen-2xl mx-auto px-6 sm:px-8 py-5">
    <div class="flex flex-wrap justify-center md:justify-between items-center gap-x-8 gap-y-4 text-xs md:text-sm text-slate-500 font-medium">
      <div class="flex items-center gap-x-2">
        <i class="fa-solid fa-shield-halved text-emerald-500"></i>
        <span>Secure escrow transactions recommended</span>
      </div>
      <div class="flex items-center gap-x-2">
        <i class="fa-solid fa-microchip text-emerald-500"></i>
        <span>PHX = Instant recognition for Phoenix tech, chips &amp; innovation</span>
      </div>
      <div class="flex items-center gap-x-2">
        <i class="fa-solid fa-chart-line text-emerald-500"></i>
        <span>.monster TLD for bold, disruptive, high-growth brands</span>
      </div>
    </div>
  </div>
</div>
