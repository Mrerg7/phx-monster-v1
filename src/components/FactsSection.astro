---
import { getCollection } from 'astro:content';

const facts = await Promise.all(
  (await getCollection('facts'))
    .sort((a, b) => a.data.order - b.data.order)
    .map(async (fact) => {
      const { Content } = await fact.render();
      return { ...fact, Content };
    })
);
---

<section id="facts" class="bg-white border-y border-slate-200 py-16">
  <div class="max-w-screen-2xl mx-auto px-6 sm:px-8">
    <div class="max-w-3xl mx-auto text-center mb-12">
      <div class="inline-block px-4 py-1 rounded-2xl bg-violet-100 text-violet-700 text-xs font-bold tracking-[1.5px] mb-4">
        PHOENIX: THE RISING TECH MONSTER OF THE SOUTHWEST
      </div>
      <h2 class="section-header tracking-tighter">
        Massive investments, talent inflow, and business-friendly fundamentals are fueling explosive growth.
      </h2>
    </div>

    <div class="max-w-6xl mx-auto grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        facts.map((fact) => (
          <div class="bg-white border border-slate-200 rounded-3xl p-8">
            <div class="flex items-center gap-x-3 mb-4">
              <div class="w-10 h-10 rounded-2xl bg-violet-600 flex items-center justify-center">
                <i class={`fa-solid ${fact.data.icon} text-white`}></i>
              </div>
              <div class="font-semibold text-xl tracking-tight">{fact.data.title}</div>
            </div>
            <div class="text-slate-600 leading-relaxed">
              <fact.Content />
            </div>
          </div>
        ))
      }
    </div>

    <div class="max-w-4xl mx-auto mt-10 text-center text-sm text-slate-500">
      Phoenix is transitioning from a fast-growing Sun Belt metro into a legitimate national tech and semiconductor powerhouse — driven by historic chip investments, corporate expansions, strong universities, and a pro-growth business climate.
    </div>
  </div>
</section>
